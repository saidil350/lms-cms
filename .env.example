# Database (PostgreSQL)
DATABASE_URI=postgresql://user:password@localhost:5432/lms_cms

# Payload CMS
PAYLOAD_SECRET=change_this_to_a_random_32_character_string_minimum
PAYLOAD_PUBLIC_SERVER_URL=https://cms.namaproject.id

# CORS — Frontend URL (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGINS=https://namaproject.id,https://www.namaproject.id

# Frontend sync / ISR revalidation
# Gunakan secret yang sama dengan REVALIDATE_SECRET di repo lms-landing-page.
FRONTEND_URL=https://namaproject.id
FRONTEND_REVALIDATE_URL=https://namaproject.id/api/revalidate
REVALIDATE_SECRET=change_this_to_the_same_secret_as_frontend

# Cloudflare R2 / S3 Compatible Storage
S3_BUCKET=lms-media
S3_ENDPOINT=https://xxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://media.namaproject.id

# Port (default 3001 — jangan bentrok dengan frontend di 3000)
PORT=3001
